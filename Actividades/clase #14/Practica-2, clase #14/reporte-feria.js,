//=====================================================
// Parte G
//=====================================================

console.log("PARTE G");

const totalCategoria = ventasFeria.reduce((acc,v)=>{

acc[v.categoria]=(acc[v.categoria]||0)+v.monto;

return acc;

},{});

console.log(totalCategoria);

const totalGeneral = ventasFeria.reduce((acc,v)=>acc+v.monto,0);

console.log(totalGeneral);

// Explicación:
// El primer reduce inicia con {} porque construye un objeto.
// El segundo inicia con 0 porque acumula un número.


